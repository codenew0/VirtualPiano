{
  "name": "virtual-piano",
  "version": "1.1.0",
  "private": true,
  "description": "A browser-based virtual piano using the Signal Factory Sound SoundFont.",
  "scripts": {
    "build": "npm run copy:worklet && esbuild ./js/audio-source.js --bundle --minify --legal-comments=inline --format=iife --platform=browser --outfile=./js/audio.js",
    "copy:worklet": "node scripts/copy-worklet.mjs"
  },
  "dependencies": {
    "spessasynth_lib": "^4.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
